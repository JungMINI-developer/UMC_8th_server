{
  "name": "node_study",
  "version": "1.0.0",
  "description": "LP service backend (TS + Express + Prisma + PostgreSQL)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
